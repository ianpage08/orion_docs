{
  "id": "recibo_aluguel",
  "version": "2.0.0",
  "title": "Declaração de Compra e Venda de Imóvel",
  "category": "declaracao",
  "description": "Declaração formal de compra e venda de imóvel rural, com quitação de valor entre vendedor e comprador.",
  "tags": ["declaração", "compra", "venda", "imóvel rural", "quitação", "rural"],
  "theme": "light",

  "layout": {
    "density": "comfortable",
    "defaultColumns": 2,
    "showSectionHeaders": true,
    "showFieldNumbers": true,
    "showProgressBar": true
  },

  "sections": [
    {
      "id": "transacao",
      "title": "Valor da Transação",
      "icon": "attach_money",
      "fields": ["valor_transacao"]
    },
    {
      "id": "vendedor",
      "title": "Dados do Vendedor (Declarante)",
      "icon": "sell",
      "description": "Quem realiza a declaração e recebeu o pagamento",
      "fields": ["nome_vendedor", "cpf_vendedor", "endereco_vendedor"]
    },
    {
      "id": "comprador",
      "title": "Dados do Comprador",
      "icon": "shopping_cart",
      "fields": ["nome_comprador", "cpf_comprador", "endereco_comprador"]
    },
    {
      "id": "imovel",
      "title": "Imóvel Negociado",
      "icon": "landscape",
      "fields": ["descricao_imovel"]
    },
    {
      "id": "assinatura",
      "title": "Assinatura",
      "icon": "draw",
      "fields": ["local_assinatura", "data_assinatura"]
    }
  ],

  "fields": [
    {
      "id": "valor_transacao",
      "label": "Valor da Transação",
      "hint": "Ex: 4.000,00",
      "type": "currency",
      "width": "half",
      "required": true,
      "icon": "attach_money",
      "prefix": "R$",
      "validation": { "min": 0.01, "message": "Informe um valor válido" }
    },
    {
      "id": "nome_vendedor",
      "label": "Nome do Vendedor (Declarante)",
      "hint": "Nome completo de quem vende e declara",
      "type": "text",
      "width": "full",
      "required": true,
      "icon": "person",
      "validation": { "minLength": 5, "maxLength": 150, "message": "Informe o nome completo" }
    },
    {
      "id": "cpf_vendedor",
      "label": "CPF do Vendedor",
      "hint": "000.000.000-00",
      "type": "cpf",
      "width": "half",
      "required": true,
      "icon": "badge",
      "mask": "###.###.###-##",
      "validation": { "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$", "message": "CPF inválido" }
    },
    {
      "id": "endereco_vendedor",
      "label": "Endereço do Vendedor",
      "hint": "Rua, número, bairro, cidade — UF",
      "type": "text",
      "width": "full",
      "required": true,
      "icon": "location_on",
      "validation": { "minLength": 10, "message": "Informe o endereço completo" }
    },
    {
      "id": "nome_comprador",
      "label": "Nome do Comprador",
      "hint": "Nome completo do adquirente",
      "type": "text",
      "width": "full",
      "required": true,
      "icon": "person_outline",
      "validation": { "minLength": 5, "maxLength": 150, "message": "Informe o nome completo" }
    },
    {
      "id": "cpf_comprador",
      "label": "CPF do Comprador",
      "hint": "000.000.000-00",
      "type": "cpf",
      "width": "half",
      "required": true,
      "icon": "badge",
      "mask": "###.###.###-##",
      "validation": { "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$", "message": "CPF inválido" }
    },
    {
      "id": "endereco_comprador",
      "label": "Endereço do Comprador",
      "hint": "Rua, número, bairro, cidade — UF",
      "type": "text",
      "width": "full",
      "required": true,
      "icon": "location_on",
      "validation": { "minLength": 10, "message": "Informe o endereço completo" }
    },
    {
      "id": "descricao_imovel",
      "label": "Descrição do Imóvel",
      "hint": "Área em hectares/m², medidas, localização (município, gleba, lote)",
      "type": "multiline",
      "width": "full",
      "required": true,
      "icon": "description",
      "validation": { "minLength": 20, "message": "Descreva o imóvel com detalhes" }
    },
    {
      "id": "local_assinatura",
      "label": "Local de Assinatura",
      "hint": "Cidade onde será assinado",
      "type": "text",
      "width": "half",
      "required": true,
      "icon": "place"
    },
    {
      "id": "data_assinatura",
      "label": "Data de Assinatura",
      "type": "date",
      "width": "half",
      "required": true,
      "icon": "today"
    }
  ],

  "pdf": {
    "pageSize": "A4",
    "orientation": "portrait",
    "margins": { "top": 48, "right": 48, "bottom": 48, "left": 48 },
    "header": {
      "showDocId": true,
      "showBadge": true,
      "badgeText": "RASCUNHO",
      "showLogo": false
    },
    "footer": {
      "appName": "Orion Docs",
      "showPageNumber": true,
      "showTimestamp": false
    },
    "typography": {
      "titleSize": 13,
      "bodySize": 11,
      "lineHeight": 1.75,
      "clauseStyle": "bold"
    },
    "signingBlocks": [
      { "role": "Vendedor",  "nameField": "nome_vendedor",  "cpfField": "cpf_vendedor" },
      { "role": "Comprador", "nameField": "nome_comprador", "cpfField": "cpf_comprador" },
      { "role": "Testemunha 1" },
      { "role": "Testemunha 2" }
    ],
    "watermark": null
  },

  "validation": {
    "requireAllFields": true,
    "crossFieldRules": []
  },

  "meta": {
    "legalBasis": "Lei nº 7.115/83; Código Civil Brasileiro — Arts. 481–532",
    "jurisdiction": "Brasil",
    "notes": "Para imóvel rural, verificar obrigatoriedade de CCIR (Certificado de Cadastro de Imóvel Rural) junto ao INCRA.",
    "estimatedTime": "5 min",
    "color": "#00897B"
  },

  "template": "DECLARAÇÃO DE COMPRA E VENDA DE IMÓVEL\n\nValor da transação: R$ {{valor_transacao}}\n\nIMÓVEL RURAL\n\nEu, {{nome_vendedor}}, portador(a) do CPF: {{cpf_vendedor}}, brasileiro(a), maior e capaz, residente em {{endereco_vendedor}}, DECLARO para os devidos fins de direito, que recebi do(a) Sr./Sra. {{nome_comprador}}, portador(a) do CPF: {{cpf_comprador}}, brasileiro(a), maior e capaz, residente e domiciliado(a) em {{endereco_comprador}}, a importância acima declarada, no valor de R$ {{valor_transacao}}, referente à venda que lhe fiz do seguinte imóvel:\n\n{{descricao_imovel}}\n\nQue a presente venda é feita em caráter irrevogável e irretratável, por si, seus herdeiros, sucessores e seus antecedentes, na forma expressa e verdadeira da lei.\n\n{{local_assinatura}}, {{data_assinatura}}.\n\n_______________________________________________\n{{nome_vendedor}}\nCPF: {{cpf_vendedor}}\n\n_______________________________________________\n{{nome_comprador}}\nCPF: {{cpf_comprador}}\n\nTESTEMUNHAS:\n_______________________________________________\n\n_______________________________________________"
}
